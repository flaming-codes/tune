{
  "$schema": "https://turborepo.dev/schema.json",
  "globalDependencies": ["apps/*/.env*"],
  "ui": "tui",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", ".next/**", "!.next/cache/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "typecheck": {
      "dependsOn": ["^typecheck"]
    },
    "test:int": {
      "dependsOn": ["^build"],
      "outputs": []
    },
    "test:e2e": {
      "cache": false,
      "outputs": []
    },
    "test": {
      "dependsOn": ["test:int"],
      "outputs": []
    },
    "format": {
      "cache": false
    },
    "build:exe": {
      "dependsOn": ["build"],
      "cache": false
    }
  }
}
