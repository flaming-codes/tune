{
  "name": "med-site-monorepo",
  "private": true,
  "version": "1.0.0",
  "packageManager": "pnpm@10.19.0",
  "scripts": {
    "prepare": "lefthook install",
    "build": "turbo run build --filter=web",
    "dev": "turbo run dev --filter=web",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck --filter=web",
    "test": "turbo run test:int --filter=web",
    "test:e2e": "turbo run test:e2e --filter=web",
    "ci:fast": "turbo run lint typecheck test:int build --filter=web --output-logs=new-only",
    "format": "pnpm --filter web format",
    "db:generate": "pnpm --filter web db:generate",
    "db:migrate": "pnpm --filter web db:migrate",
    "seed:start-page": "pnpm --filter web seed:start-page"
  },
  "devDependencies": {
    "lefthook": "^2.1.1",
    "turbo": "^2.5.8"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "sharp",
      "esbuild",
      "unrs-resolver"
    ],
    "ignoredBuiltDependencies": [
      "lefthook"
    ]
  }
}
