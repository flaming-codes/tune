{
  "name": "web",
  "version": "1.0.0",
  "description": "A blank template to get started with Payload 3.0",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "build": "cross-env NODE_OPTIONS=\"--no-deprecation --max-old-space-size=8000\" next build",
    "dev": "cross-env NODE_OPTIONS=--no-deprecation next dev",
    "devsafe": "rm -rf .next && cross-env NODE_OPTIONS=--no-deprecation next dev",
    "generate:importmap": "cross-env NODE_OPTIONS=--no-deprecation payload generate:importmap",
    "generate:types": "cross-env NODE_OPTIONS=--no-deprecation payload generate:types",
    "db:generate": "pnpm run generate:types && pnpm run generate:importmap",
    "db:migrate": "cross-env NODE_OPTIONS=--no-deprecation payload migrate",
    "db:migrate:create": "cross-env NODE_OPTIONS=--no-deprecation payload migrate:create",
    "db:migrate:reset": "cross-env NODE_OPTIONS=--no-deprecation payload migrate:reset",
    "db:migrate:fresh": "cross-env NODE_OPTIONS=--no-deprecation payload migrate:fresh",
    "db:migrate:status": "cross-env NODE_OPTIONS=--no-deprecation payload migrate:status",
    "seed:start-page": "cross-env NODE_OPTIONS=--no-deprecation node --import=tsx/esm src/seed/runStartPageSeed.ts",
    "lint": "cross-env NODE_OPTIONS=--no-deprecation eslint .",
    "format": "prettier --write \"src/**/*.{ts,tsx,js,jsx,json,css,scss,md}\" \"tests/**/*.{ts,tsx}\"",
    "payload": "cross-env NODE_OPTIONS=--no-deprecation payload",
    "start": "cross-env NODE_OPTIONS=--no-deprecation next start",
    "test": "pnpm run test:int && pnpm run test:e2e",
    "test:e2e": "cross-env NODE_OPTIONS=\"--no-deprecation --import=tsx/esm\" playwright test --config=playwright.config.ts",
    "test:int": "cross-env NODE_OPTIONS=--no-deprecation vitest run --config ./vitest.config.mts"
  },
  "dependencies": {
    "@payloadcms/db-sqlite": "3.77.0",
    "@payloadcms/live-preview-react": "^3.77.0",
    "@payloadcms/next": "3.77.0",
    "@payloadcms/richtext-lexical": "3.77.0",
    "@payloadcms/ui": "3.77.0",
    "@radix-ui/react-navigation-menu": "^1.2.14",
    "@tailwindcss/postcss": "^4.2.0",
    "clsx": "^2.1.1",
    "cross-env": "^10.1.0",
    "dotenv": "17.3.1",
    "graphql": "^16.12.0",
    "leaflet": "^1.9.4",
    "motion": "^12.34.3",
    "next": "16.1.6",
    "payload": "3.77.0",
    "postcss": "^8.5.6",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-leaflet": "^5.0.0",
    "sharp": "0.34.5",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@playwright/test": "1.58.2",
    "@testing-library/react": "16.3.2",
    "@types/leaflet": "^1.9.21",
    "@types/node": "25.3.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "5.1.4",
    "eslint": "^9.39.3",
    "eslint-config-next": "16.1.6",
    "jsdom": "28.1.0",
    "prettier": "^3.8.1",
    "tsx": "4.21.0",
    "typescript": "5.9.3",
    "vite-tsconfig-paths": "6.1.1",
    "vitest": "4.0.18"
  },
  "engines": {
    "node": "^18.20.2 || >=20.9.0",
    "pnpm": "^9 || ^10"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "sharp",
      "esbuild",
      "unrs-resolver"
    ]
  }
}
